<UserControl x:Class="SandwicheriaWalterio.Views.ProductosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:SandwicheriaWalterio.ViewModels"
             Background="{DynamicResource BackgroundPrimary}">

    <UserControl.DataContext>
        <viewmodels:ProductosViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🍔 GESTIÓN DE MENÚ" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,5,0,0">
                <Run Text="Productos y Recetas disponibles para venta - "/>
                <Run Text="{Binding TotalItems, Mode=OneWay}" FontWeight="Bold"/>
                <Run Text=" items ("/>
                <Run Text="{Binding TotalProductos, Mode=OneWay}"/>
                <Run Text=" productos, "/>
                <Run Text="{Binding TotalRecetas, Mode=OneWay}"/>
                <Run Text=" recetas)"/>
            </TextBlock>
        </StackPanel>

        <!-- Barra de herramientas -->
        <Border Grid.Row="1" Background="{DynamicResource BackgroundSecondary}" CornerRadius="8"
                Padding="15" Margin="0,0,0,15" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <!-- Botón Nuevo Producto -->
                <Button Grid.Column="0" Command="{Binding NuevoProductoCommand}" Content="➕ Producto (F1)" 
                        Padding="12,10" Background="#3498DB" Foreground="White" FontSize="12" 
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Botón Nueva Receta -->
                <Button Grid.Column="2" Command="{Binding NuevaRecetaCommand}" Content="🍕 Receta" 
                        Padding="12,10" Background="#E67E22" Foreground="White" FontSize="12" 
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#D35400"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Buscador -->
                <TextBox Grid.Column="4" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="10" VerticalContentAlignment="Center"/>

                <!-- Filtro de categoría -->
                <ComboBox Grid.Column="6" ItemsSource="{Binding Categorias}"
                          SelectedValue="{Binding CategoriaFiltroSeleccionada}" SelectedValuePath="CategoriaID"
                          DisplayMemberPath="Nombre" FontSize="14" Padding="8"/>
            </Grid>
        </Border>

        <!-- Lista de items (productos + recetas) -->
        <Border Grid.Row="2" Background="{DynamicResource BackgroundSecondary}" CornerRadius="8" 
                Padding="15" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Encabezado -->
                <Border Grid.Row="0" Background="{DynamicResource BackgroundTertiary}" Padding="10" 
                        CornerRadius="5" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TIPO" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="NOMBRE / DESCRIPCIÓN" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="CATEGORÍA" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                        <TextBlock Grid.Column="3" Text="PRECIO" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="STOCK" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="MÍNIMO" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="ACCIONES" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Lista -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                                        Background="{DynamicResource BackgroundSecondary}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BackgroundTertiary}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Tipo (Badge) -->
                                        <Border Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Padding="8,4" CornerRadius="10" Background="{Binding ColorFondo}">
                                            <TextBlock Text="{Binding Icono}" Foreground="White" FontSize="14"/>
                                        </Border>

                                        <!-- Nombre y Descripción -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                <Border Background="#E67E22" CornerRadius="8" Padding="6,2" Margin="8,0,0,0"
                                                        Visibility="{Binding EsReceta, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="RECETA" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Descripcion}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Categoría -->
                                        <TextBlock Grid.Column="2" Text="{Binding Categoria}" VerticalAlignment="Center"
                                                   FontSize="13" Foreground="{DynamicResource TextSecondary}"/>

                                        <!-- Precio -->
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" TextAlignment="Right"
                                                   FontWeight="Bold" Foreground="#27AE60" FontSize="14"
                                                   Text="{Binding Precio, StringFormat='${0:N0}'}"/>

                                        <!-- Stock -->
                                        <Border Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Padding="12,5" CornerRadius="12" MinWidth="45">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#27AE60"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StockBajo}" Value="True">
                                                            <Setter Property="Background" Value="#E74C3C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StockActual, StringFormat='{}{0:0}'}" Foreground="White" FontSize="12"
                                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </Border>

                                        <!-- Stock Mínimo -->
                                        <Border Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Padding="10,4" CornerRadius="10" MinWidth="40" Background="#F39C12">
                                            <TextBlock Text="{Binding StockMinimo, StringFormat='{}{0:0}'}" Foreground="White" FontSize="11"
                                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </Border>

                                        <!-- Acciones -->
                                        <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="✏️" Width="32" Height="32" Background="#3498DB" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand" Margin="0,0,5,0" ToolTip="Editar"
                                                    Command="{Binding DataContext.EditarItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="🗑️" Width="32" Height="32" Background="#E74C3C" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand" ToolTip="Eliminar"
                                                    Command="{Binding DataContext.EliminarItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Botón Actualizar -->
        <Button Grid.Row="3" Command="{Binding ActualizarCommand}" Content="🔄 Actualizar (F5)"
                HorizontalAlignment="Right" Margin="0,15,0,0" Padding="15,10"
                Background="{DynamicResource BackgroundSecondary}" Foreground="{DynamicResource TextPrimary}"
                BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Cursor="Hand" FontSize="12">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</UserControl>
