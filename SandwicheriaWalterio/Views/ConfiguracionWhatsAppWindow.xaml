<Window x:Class="SandwicheriaWalterio.Views.ConfiguracionWhatsAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Configuración de WhatsApp" 
        Height="550" Width="520"
        MinHeight="500" MinWidth="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#ECF0F1">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <fa:IconImage Icon="Whatsapp" Width="32" Height="32" Foreground="#25D366"/>
                <TextBlock Text="CONFIGURACIÓN WHATSAPP" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Configure las notificaciones de ventas por WhatsApp" FontSize="12" Foreground="#7F8C8D" Margin="44,5,0,0"/>
        </StackPanel>

        <!-- Formulario -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
                <StackPanel>
                    <!-- Habilitar/Deshabilitar -->
                    <CheckBox x:Name="chkHabilitado" Content="📱 Habilitar notificaciones por WhatsApp" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,25"/>

                    <!-- Número de teléfono -->
                    <TextBlock Text="Número de WhatsApp destino:" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                    <TextBlock Text="(Incluya código de país, ej: 549381xxxxxxx para Argentina)" FontSize="11" Foreground="#95A5A6" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtNumero" Grid.Column="0" Padding="12" FontSize="15"/>
                        <Button x:Name="btnBorrarNumero" Grid.Column="1" Content="✕" Width="40" Height="40" Margin="8,0,0,0"
                                Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="16" FontWeight="Bold"
                                Click="BtnBorrarNumero_Click" ToolTip="Borrar número"/>
                    </Grid>

                    <!-- Información -->
                    <Border Background="#E8F6FF" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="📋 Información:" FontSize="13" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,10"/>
                            <TextBlock Text="• Cada venta completada enviará un resumen automático" FontSize="12" Foreground="#2980B9" TextWrapping="Wrap"/>
                            <TextBlock Text="• Se abrirá WhatsApp Web con el mensaje listo para enviar" FontSize="12" Foreground="#2980B9" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            <TextBlock Text="• Incluye: Nº de venta, productos, total y vendedor" FontSize="12" Foreground="#2980B9" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Botón de prueba -->
                    <Button x:Name="btnProbar" Content="🔔 Enviar mensaje de prueba" Margin="0,20,0,0" Padding="15,12" 
                            Background="#25D366" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13"
                            Click="BtnProbar_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnCancelar" Content="Cancelar" Width="100" Height="40" Margin="0,0,10,0"
                    Background="#95A5A6" Foreground="White" BorderThickness="0" Click="BtnCancelar_Click" Cursor="Hand" FontSize="13"/>
            <Button x:Name="btnGuardar" Content="💾 Guardar" Width="120" Height="40"
                    Background="#27AE60" Foreground="White" BorderThickness="0" Click="BtnGuardar_Click" Cursor="Hand" FontWeight="Bold" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>
