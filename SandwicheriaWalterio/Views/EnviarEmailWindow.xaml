<Window x:Class="SandwicheriaWalterio.Views.EnviarEmailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📧 Enviar Reporte por Email" 
        Height="580" Width="480"
        MinHeight="500" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#ECF0F1">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="📧 Enviar Reporte por Email" 
                           FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Configura los datos y envía el reporte Excel" 
                           FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Configuración del remitente -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📤 CONFIGURACIÓN DEL REMITENTE" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Tu Email (Gmail):" FontSize="12" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtEmailRemitente" Padding="10" Margin="0,5,0,10" FontSize="13"/>
                    
                    <TextBlock Text="Contraseña de Aplicación:" FontSize="12" Foreground="#7F8C8D"/>
                    <PasswordBox x:Name="txtPassword" Padding="10" Margin="0,5,0,5" FontSize="13"/>
                    
                    <TextBlock Text="💡 Usa una 'Contraseña de Aplicación' de Google, no tu contraseña normal" 
                               FontSize="10" Foreground="#3498DB" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Destinatario -->
            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📥 DESTINATARIO" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Email del destinatario:" FontSize="12" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtEmailDestino" Padding="10" Margin="0,5,0,10" FontSize="13"/>
                    
                    <TextBlock Text="Asunto:" FontSize="12" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtAsunto" Padding="10" Margin="0,5,0,0" FontSize="13"
                             Text="Reporte de Ventas - Sandwichería Walterio"/>
                </StackPanel>
            </Border>

            <!-- Información del reporte -->
            <Border Grid.Row="3" Background="#E8F6FF" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📊 REPORTE A ENVIAR" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtInfoReporte" FontSize="12" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Botones -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,10">
                <Button x:Name="btnCancelar" Content="Cancelar" 
                        Width="100" Height="38" Margin="0,0,10,0"
                        Background="#95A5A6" Foreground="White" BorderThickness="0"
                        Click="BtnCancelar_Click" Cursor="Hand"/>
                
                <Button x:Name="btnEnviar" Content="📧 Enviar Email" 
                        Width="130" Height="38"
                        Background="#27AE60" Foreground="White" BorderThickness="0"
                        Click="BtnEnviar_Click" Cursor="Hand" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
