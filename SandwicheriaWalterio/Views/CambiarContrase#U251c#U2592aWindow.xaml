<Window x:Class="SandwicheriaWalterio.Views.CambiarContraseñaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔑 Cambiar Contraseña" 
        Height="420" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECF0F1">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🔑 CAMBIAR CONTRASEÑA" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock x:Name="txtUsuario" Text="Usuario: " FontSize="13" Foreground="#7F8C8D" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Formulario -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="25" BorderBrush="#BDC3C7" BorderThickness="1">
            <StackPanel>
                <!-- Nueva contraseña -->
                <TextBlock Text="Nueva Contraseña *" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                <PasswordBox x:Name="txtNuevaContraseña" Padding="12" FontSize="15" Height="42" Margin="0,0,0,20"/>

                <!-- Confirmar contraseña -->
                <TextBlock Text="Confirmar Nueva Contraseña *" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                <PasswordBox x:Name="txtConfirmarContraseña" Padding="12" FontSize="15" Height="42" Margin="0,0,0,20"/>

                <!-- Indicador de seguridad -->
                <Border Background="#F8F9FA" CornerRadius="5" Padding="12">
                    <StackPanel>
                        <TextBlock Text="💡 Recomendaciones:" FontSize="12" FontWeight="Bold" Foreground="#7F8C8D"/>
                        <TextBlock Text="• Mínimo 4 caracteres" FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                        <TextBlock Text="• Combina letras y números" FontSize="12" Foreground="#7F8C8D"/>
                        <TextBlock Text="• Evita datos personales" FontSize="12" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Width="110" Height="40" Margin="0,0,10,0" FontSize="14"
                    Background="#95A5A6" Foreground="White" BorderThickness="0" Click="BtnCancelar_Click" Cursor="Hand"/>
            <Button Content="🔑 Cambiar" Width="130" Height="40" FontSize="14"
                    Background="#9B59B6" Foreground="White" BorderThickness="0" Click="BtnCambiar_Click" Cursor="Hand" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
