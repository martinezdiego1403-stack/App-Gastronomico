<Window x:Class="SandwicheriaWalterio.Views.ProductoFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Producto" 
        Height="620" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECF0F1">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock x:Name="txtTitulo"
                   Grid.Row="0"
                   Text="NUEVO PRODUCTO"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Formulario -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Nombre -->
                <TextBlock Text="Nombre del producto *"
                           FontSize="13"
                           Foreground="#7F8C8D"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtNombre"
                         FontSize="14"
                         Padding="10"
                         Height="40"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         Margin="0,0,0,15"/>

                <!-- Código de Barras -->
                <TextBlock Text="Código de Barras (opcional)"
                           FontSize="13"
                           Foreground="#7F8C8D"
                           Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtCodigoBarras"
                             Grid.Column="0"
                             FontSize="14"
                             Padding="10"
                             Height="40"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"/>
                    <Border Grid.Column="1" Background="#E8F6FF" CornerRadius="5" Padding="10,0" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="📷" FontSize="18" VerticalAlignment="Center" ToolTip="Escanea o escribe el código"/>
                    </Border>
                </Grid>

                <!-- Categoría -->
                <TextBlock Text="Categoría *"
                           FontSize="13"
                           Foreground="#7F8C8D"
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbCategoria"
                          FontSize="14"
                          Padding="10"
                          Height="40"
                          BorderBrush="#BDC3C7"
                          BorderThickness="1"
                          Margin="0,0,0,15"/>

                <!-- Descripción -->
                <TextBlock Text="Descripción"
                           FontSize="13"
                           Foreground="#7F8C8D"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtDescripcion"
                         FontSize="14"
                         Padding="10"
                         Height="70"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         Margin="0,0,0,15"/>

                <!-- Grid para Precio y Stock -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Precio -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Precio *"
                                   FontSize="13"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPrecio"
                                 FontSize="14"
                                 Padding="10"
                                 Height="40"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"/>
                    </StackPanel>

                    <!-- Unidad de medida -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Unidad *"
                                   FontSize="13"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbUnidad"
                                  FontSize="14"
                                  Padding="10"
                                  Height="40"
                                  BorderBrush="#BDC3C7"
                                  BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <!-- Grid para Stocks -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Stock Actual -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Stock Actual *"
                                   FontSize="13"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="txtStockActual"
                                 FontSize="14"
                                 Padding="10"
                                 Height="40"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"/>
                    </StackPanel>

                    <!-- Stock Mínimo -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Stock Mínimo *"
                                   FontSize="13"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="txtStockMinimo"
                                 FontSize="14"
                                 Padding="10"
                                 Height="40"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <!-- CheckBox Activo -->
                <CheckBox x:Name="chkActivo"
                          Content="Producto activo"
                          FontSize="13"
                          Foreground="#2C3E50"
                          IsChecked="True"
                          Margin="0,5,0,0"/>

                <!-- Mensaje de error -->
                <TextBlock x:Name="txtError"
                           Text=""
                           FontSize="12"
                           Foreground="#E74C3C"
                           TextWrapping="Wrap"
                           Margin="0,15,0,0"
                           Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Botones -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Cancelar"
                    Click="BtnCancelar_Click"
                    Height="45"
                    FontSize="14"
                    Background="#95A5A6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7F8C8D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2"
                    x:Name="btnGuardar"
                    Content="💾 GUARDAR"
                    Click="BtnGuardar_Click"
                    Height="45"
                    FontSize="14"
                    Background="#27AE60"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#229954"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>