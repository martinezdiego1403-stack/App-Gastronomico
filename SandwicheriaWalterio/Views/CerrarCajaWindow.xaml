<Window x:Class="SandwicheriaWalterio.Views.CerrarCajaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cerrar Caja" 
        Height="650" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECF0F1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="txtTitulo"
                       Text="CERRAR CAJA #1"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="txtInfoCaja"
                       Text="Apertura: 09/01/2025 08:30 - Usuario: Admin"
                       FontSize="12"
                       Foreground="#7F8C8D"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Contenido -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Resumen de ventas -->
                <Border Background="White"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,15"
                        BorderBrush="#BDC3C7"
                        BorderThickness="1">

                    <StackPanel>
                        <TextBlock Text="📊 RESUMEN DE VENTAS DEL DÍA"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Total de ventas realizadas:"
                                       FontSize="13"
                                       Foreground="#7F8C8D"/>
                            <TextBlock x:Name="txtCantidadVentas"
                                       Text="0"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="#2C3E50"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Height="1" Background="#ECF0F1" Margin="0,10,0,15"/>

                        <!-- Ventas por método de pago -->
                        <Grid x:Name="gridEfectivo" Margin="0,0,0,8" Visibility="Collapsed">
                            <TextBlock Text="💵 Efectivo:"
                                       FontSize="13"
                                       Foreground="#7F8C8D"/>
                            <TextBlock x:Name="txtEfectivo"
                                       Text="$ 0.00"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#27AE60"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid x:Name="gridTarjeta" Margin="0,0,0,8" Visibility="Collapsed">
                            <TextBlock Text="💳 Tarjeta:"
                                       FontSize="13"
                                       Foreground="#7F8C8D"/>
                            <TextBlock x:Name="txtTarjeta"
                                       Text="$ 0.00"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#3498DB"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid x:Name="gridTransferencia" Margin="0,0,0,8" Visibility="Collapsed">
                            <TextBlock Text="🏦 Transferencia:"
                                       FontSize="13"
                                       Foreground="#7F8C8D"/>
                            <TextBlock x:Name="txtTransferencia"
                                       Text="$ 0.00"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#9B59B6"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Height="2" Background="#2C3E50" Margin="0,10"/>

                        <Grid>
                            <TextBlock Text="TOTAL VENTAS:"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock x:Name="txtTotalVentas"
                                       Text="$ 0.00"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#27AE60"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Cierre de caja -->
                <Border Background="White"
                        CornerRadius="8"
                        Padding="20"
                        BorderBrush="#BDC3C7"
                        BorderThickness="1">

                    <StackPanel>
                        <TextBlock Text="💰 CIERRE DE CAJA"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Monto inicial:"
                                       FontSize="13"
                                       Foreground="#7F8C8D"/>
                            <TextBlock x:Name="txtMontoInicial"
                                       Text="$ 0.00"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="+ Total ventas:"
                                       FontSize="13"
                                       Foreground="#7F8C8D"/>
                            <TextBlock x:Name="txtTotalVentas2"
                                       Text="$ 0.00"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Height="1" Background="#ECF0F1" Margin="0,5,0,10"/>

                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="= Monto esperado:"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock x:Name="txtMontoEsperado"
                                       Text="$ 0.00"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#3498DB"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Height="2" Background="#ECF0F1" Margin="0,0,0,15"/>

                        <!-- Monto contado -->
                        <TextBlock Text="Monto contado en caja:"
                                   FontSize="13"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,5"/>

                        <TextBox x:Name="txtMontoContado"
                                 FontSize="18"
                                 Padding="10"
                                 Height="45"
                                 BorderBrush="#3498DB"
                                 BorderThickness="2"
                                 TextChanged="TxtMontoContado_TextChanged"
                                 Margin="0,0,0,15"/>

                        <!-- Diferencia -->
                        <Grid>
                            <TextBlock Text="Diferencia:"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock x:Name="txtDiferencia"
                                       Text="$ 0.00"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#95A5A6"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock x:Name="txtMensajeDiferencia"
                                   Text=""
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   HorizontalAlignment="Right"
                                   Margin="0,3,0,15"/>

                        <!-- Observaciones -->
                        <TextBlock Text="Observaciones (opcional):"
                                   FontSize="13"
                                   Foreground="#7F8C8D"
                                   Margin="0,10,0,5"/>

                        <TextBox x:Name="txtObservaciones"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="10"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Botones -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Cancelar"
                    Click="BtnCancelar_Click"
                    Height="45"
                    FontSize="14"
                    Background="#95A5A6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"/>

            <Button Grid.Column="2"
                    x:Name="btnCerrar"
                    Content="💾 CERRAR CAJA"
                    Click="BtnCerrar_Click"
                    Height="45"
                    FontSize="14"
                    Background="#E74C3C"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
