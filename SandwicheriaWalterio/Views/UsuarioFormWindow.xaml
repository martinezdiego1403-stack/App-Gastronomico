<Window x:Class="SandwicheriaWalterio.Views.UsuarioFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Usuario" 
        Height="400" Width="450"
        MinHeight="350" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#ECF0F1">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <fa:IconImage x:Name="iconTitulo" Icon="UserPlus" Width="28" Height="28" Foreground="#3498DB"/>
                <TextBlock x:Name="txtTitulo" Text="NUEVO USUARIO" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Complete los datos del usuario" FontSize="12" Foreground="#7F8C8D" Margin="40,5,0,0"/>
        </StackPanel>

        <!-- Formulario simplificado -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
                <StackPanel>
                    <!-- Nombre de usuario -->
                    <TextBlock Text="Nombre de Usuario *" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNombreUsuario" Padding="12" FontSize="14" Margin="0,0,0,18"/>

                    <!-- Rol -->
                    <TextBlock Text="Rol *" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbRol" Padding="12" FontSize="14" Margin="0,0,0,18">
                        <ComboBoxItem Content="👑 Dueño" Tag="Dueño"/>
                        <ComboBoxItem Content="👤 Empleado" Tag="Empleado"/>
                    </ComboBox>

                    <!-- Activo -->
                    <CheckBox x:Name="chkActivo" Content="Usuario Activo" IsChecked="True" FontSize="14" Margin="0,5,0,15"/>
                    
                    <!-- Nota informativa -->
                    <Border Background="#E8F6FF" CornerRadius="5" Padding="12" Margin="0,5,0,0">
                        <StackPanel>
                            <TextBlock Text="💡 Información:" FontSize="12" FontWeight="Bold" Foreground="#2980B9"/>
                            <TextBlock Text="• La contraseña por defecto será el nombre de usuario" FontSize="11" Foreground="#2980B9" Margin="0,5,0,0"/>
                            <TextBlock Text="• El usuario puede cambiarla después de iniciar sesión" FontSize="11" Foreground="#2980B9"/>
                            <TextBlock Text="• Los usuarios inactivos no pueden iniciar sesión" FontSize="11" Foreground="#2980B9"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnCancelar" Content="Cancelar" Width="110" Height="42" Margin="0,0,10,0"
                    Background="#95A5A6" Foreground="White" BorderThickness="0" Click="BtnCancelar_Click" 
                    Cursor="Hand" FontSize="14"/>
            <Button x:Name="btnGuardar" Content="💾 Guardar" Width="130" Height="42"
                    Background="#27AE60" Foreground="White" BorderThickness="0" Click="BtnGuardar_Click" 
                    Cursor="Hand" FontWeight="Bold" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
