<UserControl x:Class="SandwicheriaWalterio.Views.RecetasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             Background="{DynamicResource BackgroundPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ENCABEZADO -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="🍕 GESTIÓN DE RECETAS" 
                          FontSize="24" FontWeight="Bold" 
                          Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Crea recetas combinando productos de mercadería" 
                          FontSize="13" Foreground="{DynamicResource TextSecondary}" 
                          Margin="0,5,0,0"/>
            </StackPanel>

            <Button x:Name="btnNuevaReceta" Grid.Column="1" Click="BtnNuevaReceta_Click"
                    Background="#27AE60" Foreground="White" 
                    Padding="20,12" FontSize="14" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <fa:IconImage Icon="Plus" Width="16" Height="16" Foreground="White"/>
                    <TextBlock Text="Nueva Receta" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- FILTROS Y BÚSQUEDA -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Búsqueda -->
            <Border Grid.Column="0" Background="{DynamicResource BackgroundSecondary}" 
                    CornerRadius="8" Padding="10,0" Margin="0,0,15,0"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <fa:IconImage Icon="Search" Width="16" Height="16" 
                                  Foreground="{DynamicResource TextSecondary}" 
                                  VerticalAlignment="Center"/>
                    <TextBox x:Name="txtBuscar" Grid.Column="1" 
                             Text="" BorderThickness="0" 
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}"
                             VerticalAlignment="Center" Margin="10,0,0,0"
                             FontSize="14" Height="38"
                             TextChanged="TxtBuscar_TextChanged"/>
                </Grid>
            </Border>

            <!-- Filtro por categoría -->
            <ComboBox x:Name="cboCategoria" Grid.Column="1" 
                      Height="38" FontSize="14"
                      SelectionChanged="CboCategoria_SelectionChanged"/>

            <!-- Botón Actualizar -->
            <Button x:Name="btnActualizar" Grid.Column="3" Click="BtnActualizar_Click"
                    Background="{DynamicResource BackgroundSecondary}" 
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="15,8" BorderThickness="1" Cursor="Hand"
                    BorderBrush="{DynamicResource BorderColor}"
                    ToolTip="Actualizar lista (F5)">
                <StackPanel Orientation="Horizontal">
                    <fa:IconImage Icon="Sync" Width="14" Height="14" 
                                  Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Actualizar" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- LISTA DE RECETAS -->
        <Border Grid.Row="2" Background="{DynamicResource BackgroundSecondary}" 
                CornerRadius="10" Padding="0"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Encabezado de tabla -->
                <Border Grid.Row="0" Background="{DynamicResource BackgroundTertiary}" 
                        CornerRadius="10,10,0,0" Padding="15,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="RECETA" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Grid.Column="1" Text="CATEGORÍA" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Grid.Column="2" Text="PRECIO" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}" TextAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="STOCK" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}" TextAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="INSUMOS" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}" TextAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="ACCIONES" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}" TextAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Lista de recetas -->
                <ListView x:Name="lvRecetas" Grid.Row="1" 
                          Background="Transparent" BorderThickness="0"
                          SelectionMode="Single"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="border" Background="Transparent" 
                                                BorderBrush="{DynamicResource BorderColor}" 
                                                BorderThickness="0,0,0,1" Padding="15,12">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" 
                                                        Value="{DynamicResource BackgroundTertiary}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background" 
                                                        Value="{DynamicResource BackgroundTertiary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>

                                <!-- Nombre y descripción -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" 
                                               FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="{Binding Descripcion}" FontSize="12" 
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="250"/>
                                </StackPanel>

                                <!-- Categoría -->
                                <TextBlock Grid.Column="1" Text="{Binding CategoriaNombre}" 
                                           VerticalAlignment="Center" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}"/>

                                <!-- Precio -->
                                <TextBlock Grid.Column="2" Text="{Binding Precio, StringFormat='$ {0:N0}'}" 
                                           VerticalAlignment="Center" TextAlignment="Right"
                                           FontWeight="SemiBold" FontSize="14"
                                           Foreground="#27AE60"/>

                                <!-- Stock -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border CornerRadius="12" Padding="10,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#27AE60"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StockBajo}" Value="True">
                                                        <Setter Property="Background" Value="#E74C3C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StockActual}" 
                                                   Foreground="White" FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <!-- Cantidad de ingredientes -->
                                <StackPanel Grid.Column="4" Orientation="Horizontal" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Background="#3498DB" CornerRadius="12" Padding="8,4">
                                        <TextBlock Text="{Binding CantidadIngredientes, StringFormat='{}{0}'}" 
                                                   Foreground="White" FontSize="11"/>
                                    </Border>
                                </StackPanel>

                                <!-- Acciones -->
                                <StackPanel Grid.Column="5" Orientation="Horizontal" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Click="BtnVerIngredientes_Click" 
                                            Tag="{Binding RecetaID}"
                                            Background="#9B59B6" Foreground="White"
                                            Padding="8,6" Margin="0,0,5,0" BorderThickness="0"
                                            Cursor="Hand" ToolTip="Ver ingredientes">
                                        <fa:IconImage Icon="List" Width="12" Height="12" Foreground="White"/>
                                    </Button>
                                    <Button Click="BtnEditarReceta_Click" 
                                            Tag="{Binding RecetaID}"
                                            Background="#3498DB" Foreground="White"
                                            Padding="8,6" Margin="0,0,5,0" BorderThickness="0"
                                            Cursor="Hand" ToolTip="Editar receta">
                                        <fa:IconImage Icon="Edit" Width="12" Height="12" Foreground="White"/>
                                    </Button>
                                    <Button Click="BtnEliminarReceta_Click" 
                                            Tag="{Binding RecetaID}"
                                            Background="#E74C3C" Foreground="White"
                                            Padding="8,6" BorderThickness="0"
                                            Cursor="Hand" ToolTip="Eliminar receta">
                                        <fa:IconImage Icon="Trash" Width="12" Height="12" Foreground="White"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Mensaje cuando no hay recetas -->
                <StackPanel x:Name="panelSinRecetas" Grid.Row="1" 
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <fa:IconImage Icon="UtensilSpoon" Width="60" Height="60" 
                                  Foreground="{DynamicResource TextSecondary}" 
                                  HorizontalAlignment="Center"/>
                    <TextBlock Text="No hay recetas registradas" FontSize="16" 
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,15,0,5"/>
                    <TextBlock Text="Haz clic en 'Nueva Receta' para crear una" FontSize="13"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
