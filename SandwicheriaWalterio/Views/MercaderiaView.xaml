<UserControl x:Class="SandwicheriaWalterio.Views.MercaderiaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:SandwicheriaWalterio.ViewModels"
             xmlns:helpers="clr-namespace:SandwicheriaWalterio.Helpers"
             Background="{DynamicResource BackgroundPrimary}">
    
    <UserControl.DataContext>
        <viewmodels:MercaderiaViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <helpers:StockConUnidadConverter x:Key="StockConUnidadConverter"/>
    </UserControl.Resources>

    <Grid>
        <!-- Panel Principal de Mercadería (visible directamente) -->
        <Grid x:Name="panelPrincipal" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="📦 GESTIÓN DE MERCADERÍA" FontSize="24" FontWeight="Bold" 
                           Foreground="{DynamicResource TextPrimary}"/>
            </Grid>

            <!-- Barra de herramientas -->
            <Border Grid.Row="1" Background="{DynamicResource BackgroundSecondary}" CornerRadius="8" Padding="15" 
                    Margin="0,0,0,15" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Botón Nueva Mercadería a la izquierda -->
                    <Button Grid.Column="0" Command="{Binding NuevoProductoCommand}" Content="➕ Nueva Mercadería (F1)" Padding="15,8" 
                            Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="12">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#219A52"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Búsqueda -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}" Width="300" Padding="10,8" 
                                 FontSize="13" VerticalContentAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding CategoriaFiltro}" ItemsSource="{Binding Categorias}" 
                                  DisplayMemberPath="Nombre" Margin="15,0,0,0" Width="150" Padding="10,8" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lista de mercadería -->
            <Border Grid.Row="2" Background="{DynamicResource BackgroundSecondary}" CornerRadius="8" Padding="15" 
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado de la tabla -->
                    <Border Grid.Row="0" Background="{DynamicResource BackgroundTertiary}" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NOMBRE / DESCRIPCIÓN" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="CATEGORÍA" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="PRECIO" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="11" TextAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="STOCK" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="11" TextAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="MÍNIMO" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="11" TextAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="ACCIONES" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="11" TextAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Lista -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Productos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" 
                                            Background="{DynamicResource BackgroundSecondary}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BackgroundTertiary}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Nombre y Descripción -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" FontSize="13" 
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                <TextBlock Text="{Binding Descripcion}" FontSize="10" 
                                                           Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Categoría -->
                                            <TextBlock Grid.Column="1" Text="{Binding CategoriaNombre}" VerticalAlignment="Center" 
                                                       FontSize="12" Foreground="{DynamicResource TextSecondary}"/>

                                            <!-- Precio -->
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" 
                                                       FontWeight="Bold" Foreground="#27AE60" FontSize="13" Margin="0,0,10,0"
                                                       Text="{Binding Precio, StringFormat='${0:N0}'}"/>

                                            <!-- Stock Actual con Unidad -->
                                            <Border Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                    Padding="8,4" CornerRadius="10" MinWidth="50" Margin="5,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#27AE60"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StockBajo}" Value="True">
                                                                <Setter Property="Background" Value="#E74C3C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource StockConUnidadConverter}">
                                                            <Binding Path="StockActual"/>
                                                            <Binding Path="UnidadMedida"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>

                                            <!-- Stock Mínimo -->
                                            <Border Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                    Padding="10,4" CornerRadius="10" MinWidth="40" Background="#F39C12" Margin="5,0">
                                                <TextBlock Text="{Binding StockMinimo, StringFormat='{}{0:0.##}'}" Foreground="White" FontSize="11" 
                                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- Acciones -->
                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="✏️" Width="30" Height="30" Background="#3498DB" Foreground="White" 
                                                        BorderThickness="0" Cursor="Hand" Margin="0,0,5,0" ToolTip="Editar"
                                                        Command="{Binding DataContext.EditarProductoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="🗑️" Width="30" Height="30" Background="#E74C3C" Foreground="White" 
                                                        BorderThickness="0" Cursor="Hand" ToolTip="Eliminar"
                                                        Command="{Binding DataContext.EliminarProductoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
