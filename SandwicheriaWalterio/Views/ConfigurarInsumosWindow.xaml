<Window x:Class="SandwicheriaWalterio.Views.ConfigurarInsumosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Descuento de Insumos" 
        Height="550" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECF0F1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="⚙️ CONFIGURAR DESCUENTO DE INSUMOS" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock Text="Vincula cada categoría del Menú con su categoría de insumos correspondiente" 
                       FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Explicación -->
        <Border Grid.Row="1" Background="#E8F6FF" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="💡 ¿Cómo funciona?" FontWeight="Bold" Foreground="#3498DB"/>
                <TextBlock Text="Cuando se venda un producto del Menú, automáticamente se descontará stock de los productos que estén en la categoría de insumos vinculada." 
                           TextWrapping="Wrap" Foreground="#2C3E50" Margin="0,5,0,0"/>
                <TextBlock Text="Ejemplo: Si vinculas 'Sandwiches' con 'Insumos Sandwiches', al vender un sandwich se descontará 1 unidad de cada producto en 'Insumos Sandwiches'." 
                           TextWrapping="Wrap" Foreground="#7F8C8D" FontSize="11" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Lista de categorías -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" BorderBrush="#BDC3C7" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Encabezado -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CATEGORÍA MENÚ" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Grid.Column="1" Text="CATEGORÍA INSUMOS" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Grid.Column="2" Text="CANTIDAD" FontWeight="Bold" Foreground="#2C3E50" TextAlignment="Center"/>
                </Grid>

                <!-- Lista -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="listaCategorias">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" BorderBrush="#ECF0F1" BorderThickness="0,0,0,1" Margin="0,0,0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Nombre de la categoría del menú -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" FontSize="14" Foreground="#2C3E50"/>
                                            <TextBlock Text="{Binding TipoCategoria}" FontSize="10" Foreground="#95A5A6"/>
                                        </StackPanel>

                                        <!-- Selector de categoría de insumos -->
                                        <ComboBox Grid.Column="1" 
                                                  ItemsSource="{Binding DataContext.CategoriasInsumos, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedValue="{Binding CategoriaInsumoID, Mode=TwoWay}"
                                                  SelectedValuePath="CategoriaID"
                                                  DisplayMemberPath="Nombre"
                                                  Margin="10,0" Padding="8" FontSize="12"/>

                                        <!-- Cantidad a descontar -->
                                        <TextBox Grid.Column="2" 
                                                 Text="{Binding CantidadDescuento, Mode=TwoWay}"
                                                 TextAlignment="Center" Padding="8" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Botones -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Cancelar" Click="BtnCancelar_Click" Height="40" 
                    Background="#95A5A6" Foreground="White" BorderThickness="0" FontSize="14" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#7F8C8D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2" Content="💾 GUARDAR CAMBIOS" Click="BtnGuardar_Click" Height="40" 
                    Background="#27AE60" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#219A52"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
