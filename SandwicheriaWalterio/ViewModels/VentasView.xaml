<UserControl x:Class="SandwicheriaWalterio.Views.VentasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:SandwicheriaWalterio.ViewModels" 
             xmlns:helpers="clr-namespace:SandwicheriaWalterio.Helpers"
             Background="{DynamicResource BackgroundPrimary}">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:RadioButtonConverter x:Key="RadioButtonConverter"/>
    </UserControl.Resources>
    
    <UserControl.DataContext>
        <viewmodels:VentasViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO: PRODUCTOS DISPONIBLES -->
        <Border Grid.Column="0" Background="{DynamicResource BackgroundSecondary}" CornerRadius="10" Padding="20" 
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="🍔 MENÚ Y RECETAS" FontSize="18" FontWeight="Bold" 
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>

                <!-- Buscador con código de barras -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Buscador principal -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="5"
                                Background="{DynamicResource BackgroundSecondary}">
                            <Grid>
                                <TextBox x:Name="txtBusqueda" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14" Padding="10" VerticalContentAlignment="Center" 
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="{DynamicResource TextPrimary}"
                                         KeyDown="TxtBusqueda_KeyDown"/>
                                <TextBlock Text="🔍 Buscar producto o escanear código..." 
                                           VerticalAlignment="Center" Margin="12,0,0,0" 
                                           Foreground="{DynamicResource TextMuted}" FontSize="13"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBusqueda}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" FontSize="12">
                            <Run Text="{Binding ItemsDisponibles.Count, Mode=OneWay}"/>
                            <Run Text=" items"/>
                        </TextBlock>
                    </Grid>

                    <!-- Indicador de modo código de barras -->
                    <Border Grid.Row="1" Background="#E8F6FF" CornerRadius="5" Padding="8" Margin="0,8,0,0">
                        <TextBlock Text="💡 Tip: Escanea el código de barras o escríbelo y presiona Enter para agregar rápidamente" 
                                   FontSize="10" Foreground="#3498DB" TextWrapping="Wrap"/>
                    </Border>
                </Grid>

                <!-- Lista de Productos y Recetas -->
                <ListBox Grid.Row="2" ItemsSource="{Binding ItemsDisponibles}" SelectedItem="{Binding ItemSeleccionado}" 
                         BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource BackgroundCard}" BorderBrush="{DynamicResource BorderColor}" 
                                    BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,10">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" BlurRadius="5" Opacity="0.1"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Nombre con icono de tipo -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icono}" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Nombre}" FontSize="16" FontWeight="SemiBold" 
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                    </StackPanel>
                                    
                                    <!-- Categoría y tipo (Receta/Producto) -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,8">
                                        <TextBlock Text="{Binding Categoria}" FontSize="11" 
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                        <Border Background="{Binding ColorFondo}" CornerRadius="3" 
                                                Padding="5,1" Margin="10,0,0,0"
                                                Visibility="{Binding EsReceta, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="RECETA" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="18" FontWeight="Bold" Foreground="#27AE60"
                                                   Text="{Binding Precio, StringFormat='${0:N0}'}"/>
                                    </Grid>

                                    <Button Grid.Row="3" Content="➕ Agregar al carrito" Margin="0,10,0,0" Height="32" 
                                            Background="#3498DB" Foreground="White" FontSize="12" BorderThickness="0" Cursor="Hand"
                                            Click="BtnAgregarItemCarrito_Click"
                                            Tag="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- PANEL DERECHO: CARRITO -->
        <Border Grid.Column="2" Background="{DynamicResource BackgroundSecondary}" CornerRadius="10" Padding="20" 
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Encabezado -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🛒 CARRITO" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" FontSize="14">
                        <Run Text="{Binding CantidadItems, Mode=OneWay}"/>
                        <Run Text=" items"/>
                    </TextBlock>
                </Grid>

                <!-- Items del carrito -->
                <ListBox Grid.Row="1" ItemsSource="{Binding CarritoItems}" BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource BackgroundTertiary}" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icono}" FontSize="13" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" FontSize="13" 
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"
                                                   Text="{Binding DetalleCarrito}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="-" Width="25" Height="25" Background="#E74C3C" Foreground="White" 
                                                BorderThickness="0" Cursor="Hand" FontWeight="Bold"
                                                Command="{Binding DataContext.DisminuirCantidadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBlock Text="{Binding Cantidad, Mode=OneWay}" Width="30" TextAlignment="Center" VerticalAlignment="Center" 
                                                   FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                        <Button Content="+" Width="25" Height="25" Background="#27AE60" Foreground="White" 
                                                BorderThickness="0" Cursor="Hand" FontWeight="Bold"
                                                Command="{Binding DataContext.AumentarCantidadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="#27AE60" Margin="15,0,0,0" 
                                                   VerticalAlignment="Center" Width="70" TextAlignment="Right"
                                                   Text="{Binding Subtotal, StringFormat='${0:N0}'}"/>
                                        <Button Content="🗑" Width="25" Height="25" Background="#95A5A6" Foreground="White" 
                                                BorderThickness="0" Cursor="Hand" Margin="10,0,0,0"
                                                Command="{Binding DataContext.EliminarItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Total y botones -->
                <StackPanel Grid.Row="2">
                    <Separator Margin="0,10"/>
                    
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="TOTAL:" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" Foreground="#27AE60"
                                   Text="{Binding Total, StringFormat='${0:N0}'}"/>
                    </Grid>

                    <!-- Método de pago -->
                    <TextBlock Text="Método de pago:" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="rbEfectivo" Content="💵 Efectivo (F1)" GroupName="MetodoPago" IsChecked="True" 
                                     Checked="RadioButton_Checked" Tag="Efectivo" Margin="0,0,15,0" FontSize="13"
                                     Foreground="{DynamicResource TextPrimary}"/>
                        <RadioButton x:Name="rbTarjeta" Content="💳 Tarjeta (F2)" GroupName="MetodoPago" 
                                     Checked="RadioButton_Checked" Tag="Tarjeta" Margin="0,0,15,0" FontSize="13"
                                     Foreground="{DynamicResource TextPrimary}"/>
                        <RadioButton x:Name="rbTransferencia" Content="📱 Transferencia (F3)" GroupName="MetodoPago" 
                                     Checked="RadioButton_Checked" Tag="Transferencia" FontSize="13"
                                     Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Cálculo de vuelto (solo para efectivo) -->
                    <Border x:Name="panelVuelto" Background="#FEF9E7" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Monto recibido -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="💵 Monto recibido:" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtMontoRecibido" Text="{Binding MontoRecibido, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" 
                                         FontSize="16" FontWeight="Bold" Padding="8" TextAlignment="Right"
                                         BorderBrush="#F39C12" BorderThickness="2"/>
                            </StackPanel>

                            <!-- Vuelto -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="💰 Vuelto:" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                                <Border Background="{Binding VueltoBackground}" CornerRadius="5" Padding="8">
                                    <TextBlock Text="{Binding VueltoTexto}" FontSize="16" FontWeight="Bold" 
                                               Foreground="{Binding VueltoForeground}" TextAlignment="Right"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Botones -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="❌ Cancelar (F5)" Command="{Binding CancelarCommand}" Height="45" FontSize="14" 
                                Background="#95A5A6" Foreground="White" FontWeight="SemiBold" Cursor="Hand" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#7F8C8D"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2" Content="💰 COBRAR (F4)" Command="{Binding CobrarCommand}" IsEnabled="{Binding PuedeCobrar}" 
                                Height="45" FontSize="14" Background="#27AE60" Foreground="White" FontWeight="SemiBold" Cursor="Hand" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#229954"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
