<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
	</startup>

	<connectionStrings>
		<add name="SandwicheriaDB"
             connectionString="Server=localhost;Database=Sandwicheria_BD;Integrated Security=true;TrustServerCertificate=true;"
             providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>